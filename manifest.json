{
  "manifest_version": 3,
  "name": "Useful Subtitle — Prime Video 英語学習",
  "version": "0.1.0",
  "description": "Prime Video の字幕の単語・フレーズ・イディオムをクリックすると Claude が日本語で解説します。",
  "permissions": ["storage"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.primevideo.com/*",
        "https://www.amazon.co.jp/gp/video/*",
        "https://www.amazon.com/gp/video/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Useful Subtitle 設定を開く"
  }
}
